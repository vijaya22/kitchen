---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Vijaya's kitchen — a collection of recipes." } = Astro.props;

const recipes = (await getCollection('recipes')).map((r) => ({
  title: r.data.title,
  tags: r.data.tags ?? [],
  url: `/recipes/${r.id.replace(/\.md$/, '')}/`,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Kitchen</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Alegreya+Sans:wght@400;500;700&family=Rye&family=Special+Elite&display=swap" rel="stylesheet" />

    <style>
      :root {
        --scene-bg: #e2e3de;
        --orange-400: #f44b14;
        --orange-500: #e8400d;
        --orange-600: #cd3002;
        --paper: #f6f1df;
        --paper-strong: #ece3c8;
        --paper-edge: #d4c49d;
        --ink: #204f49;
        --ink-soft: #487067;
        --ink-muted: #6f857d;
        --accent: #ef7b3f;
        --gold: #c79f2d;
        --shadow: rgba(40, 21, 9, 0.22);
        --font-display: 'Rye', Georgia, serif;
        --font-body: 'Alegreya Sans', 'Trebuchet MS', sans-serif;
        --font-mono: 'Special Elite', 'Courier New', monospace;
        --radius-lg: 24px;
        --radius-md: 14px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: radial-gradient(circle at top, #f7f7f3 0%, var(--scene-bg) 56%, #d7d8d2 100%);
        color: var(--ink);
        font-family: var(--font-body);
        font-size: 1.125rem;
        line-height: 1.45;
        min-height: 100vh;
      }

      a { color: inherit; text-decoration: none; }

      header {
        width: min(1260px, calc(100% - 2.4rem));
        margin: 1rem auto 0.8rem;
        background: rgba(248, 246, 239, 0.95);
        border: 1px solid #ded8c3;
        border-radius: 999px;
        padding: 0.75rem 1rem 0.75rem 1.35rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: 0 8px 24px rgba(58, 39, 14, 0.1);
        position: relative;
      }

      .site-name {
        font-family: var(--font-display);
        font-size: clamp(1.05rem, 2vw, 1.35rem);
        letter-spacing: 0.04em;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .site-name span {
        font-size: 1.25rem;
        transform: rotate(-6deg);
      }

      header nav a {
        font-size: 0.82rem;
        color: var(--ink-soft);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
        padding: 0.46rem 1.05rem;
        border-radius: 999px;
        border: 1px solid #c9b98f;
        transition: all 0.25s ease;
      }

      header nav a:hover {
        background: var(--ink);
        border-color: var(--ink);
        color: #fdf8eb;
      }

      .header-default {
        display: contents;
      }

      header.searching .header-default {
        display: none;
      }

      .search-input {
        display: none;
        flex: 1;
        border: none;
        background: transparent;
        font-family: var(--font-body);
        font-size: 1.05rem;
        color: var(--ink);
        outline: none;
        min-width: 0;
      }

      .search-input::placeholder {
        color: var(--ink-muted);
      }

      header.searching .search-input {
        display: block;
      }

      header.searching {
        cursor: text;
      }

      .search-results {
        display: none;
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 0;
        right: 0;
        background:
          linear-gradient(150deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0)),
          var(--paper);
        border: 1px solid var(--paper-edge);
        border-radius: 14px;
        padding: 0.6rem 0.75rem;
        box-shadow: 0 10px 22px rgba(72, 32, 11, 0.22);
        max-height: 320px;
        overflow-y: auto;
        z-index: 20;
        list-style: none;
      }

      .search-results.open {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      :global(.search-results a) {
        display: block;
        padding: 0.4rem 0.5rem;
        border-radius: 8px;
        font-family: var(--font-display);
        font-size: clamp(0.9rem, 1.8vw, 1.08rem);
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: none;
        transition: color 0.2s ease, background 0.2s ease;
      }

      :global(.search-results a:hover) {
        color: #a33d0f;
        background: rgba(32, 79, 73, 0.06);
      }

      :global(.search-results .no-results) {
        padding: 0.4rem 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--ink-muted);
      }

      main {
        width: min(1260px, calc(100% - 2.4rem));
        margin: 0 auto 2.4rem;
        padding: clamp(1.2rem, 2vw, 2.2rem);
        background: linear-gradient(145deg, var(--orange-400), var(--orange-500) 55%, var(--orange-600));
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        box-shadow: 0 22px 44px var(--shadow), inset 0 0 0 1px rgba(247, 175, 140, 0.24);
        animation: stage-enter 480ms ease-out;
      }

      main::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(circle at 18% 14%, rgba(255, 170, 139, 0.22) 0 3px, transparent 3px),
          radial-gradient(circle at 74% 36%, rgba(255, 193, 161, 0.12) 0 2px, transparent 2px),
          linear-gradient(35deg, rgba(190, 35, 5, 0.16), transparent 45%);
        background-size: 240px 240px, 190px 190px, 100% 100%;
        mix-blend-mode: soft-light;
        pointer-events: none;
      }

      main > * {
        position: relative;
        z-index: 1;
      }

      @keyframes stage-enter {
        from {
          transform: translateY(12px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      @media (max-width: 720px) {
        header {
          width: calc(100% - 1.4rem);
          margin: 0.7rem auto;
          border-radius: 18px;
          padding: 0.65rem 0.8rem;
        }

        .site-name {
          font-size: 0.92rem;
          letter-spacing: 0.03em;
        }

        header nav a {
          padding: 0.4rem 0.72rem;
          font-size: 0.72rem;
        }

        main {
          width: calc(100% - 1.4rem);
          margin-bottom: 1rem;
          border-radius: 20px;
          padding: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <header id="header">
      <div class="header-default">
        <a class="site-name" href="/">
          <span>🍳</span> Kitchen
        </a>
        <nav>
          <a href="/">All recipes</a>
        </nav>
      </div>
      <input class="search-input" id="search-input" type="text" placeholder="Search recipes..." autocomplete="off" />
      <div class="search-results" id="search-results"></div>
    </header>

    <script define:vars={{ recipes }}>
      const header = document.getElementById('header');
      const input = document.getElementById('search-input');
      const resultsEl = document.getElementById('search-results');

      function openSearch() {
        header.classList.add('searching');
        input.focus();
      }

      function closeSearch() {
        header.classList.remove('searching');
        resultsEl.classList.remove('open');
        input.value = '';
      }

      header.addEventListener('click', (e) => {
        if (e.target.closest('a')) return;
        if (!header.classList.contains('searching')) openSearch();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeSearch();
      });

      input.addEventListener('input', () => {
        const query = input.value.trim().toLowerCase();
        if (!query) {
          resultsEl.classList.remove('open');
          return;
        }

        const matches = recipes.filter((r) => {
          const haystack = (r.title + ' ' + r.tags.join(' ')).toLowerCase();
          return query.split(/\s+/).every((word) => haystack.includes(word));
        });

        if (matches.length > 0) {
          resultsEl.innerHTML = matches
            .map((r) => `<a href="${r.url}">${r.title}</a>`)
            .join('');
        } else {
          resultsEl.innerHTML = '<div class="no-results">No recipes found</div>';
        }
        resultsEl.classList.add('open');
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('header')) closeSearch();
      });
    </script>
    <main>
      <slot />
    </main>
  </body>
</html>
