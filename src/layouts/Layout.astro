---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Vijaya's kitchen — a collection of recipes." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Kitchen</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />

    <style>
      :root {
        --bg: #fff8f0;
        --card: #ffffff;
        --text: #2c1810;
        --muted: #8b6f5e;
        --accent: #c9552a;
        --accent-light: #fff0e6;
        --green: #5a7a45;
        --green-light: #eef5e8;
        --border: #ede0d4;
        --shadow: rgba(180, 100, 50, 0.08);
        --font-serif: 'Playfair Display', Georgia, serif;
        --font-sans: 'DM Sans', system-ui, sans-serif;
        --radius: 16px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 1rem;
        line-height: 1.6;
        min-height: 100vh;
      }

      a { color: inherit; text-decoration: none; }

      header {
        background: var(--card);
        border-bottom: 1px solid var(--border);
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
        box-shadow: 0 2px 12px var(--shadow);
      }

      .site-name {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }

      .site-name span {
        font-size: 1.4rem;
      }

      header nav a {
        font-size: 0.875rem;
        color: var(--muted);
        font-weight: 500;
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        transition: all 0.2s;
      }

      header nav a:hover {
        background: var(--accent-light);
        border-color: var(--accent);
        color: var(--accent);
      }

      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }
    </style>
  </head>
  <body>
    <header>
      <a class="site-name" href="/">
        <span>🍳</span> Kitchen
      </a>
      <nav>
        <a href="/">All recipes</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
