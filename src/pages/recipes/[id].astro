---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { id: recipe.id.replace(/\.md$/, '') },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { title, description, tags, image } = recipe.data;

const emoji =
  (tags ?? []).includes('salad') ? '🥗' :
  (tags ?? []).includes('soup') ? '🍲' :
  (tags ?? []).includes('indian') ? '🍛' :
  (tags ?? []).includes('chicken') ? '🍗' :
  (tags ?? []).includes('vegan') ? '🌱' : '🍴';
---

<Layout title={title} description={description}>
  <style>
    .back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff3e4;
      font-weight: 700;
      padding: 0.44rem 0.92rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 231, 194, 0.45);
      background: rgba(14, 58, 52, 0.32);
      margin-bottom: 0.95rem;
      transition: all 0.24s ease;
    }

    .back:hover {
      background: rgba(14, 58, 52, 0.78);
      border-color: rgba(255, 234, 206, 0.8);
    }

    .spread {
      --divider-x: 54%;
      background:
        linear-gradient(152deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0)),
        var(--paper);
      border: 1px solid var(--paper-edge);
      border-radius: 14px;
      box-shadow: 0 18px 36px rgba(41, 19, 7, 0.34);
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
      min-height: 70vh;
      position: relative;
      overflow: hidden;
      animation: enter-spread 500ms ease-out;
    }

    .spread::after {
      content: '';
      position: absolute;
      top: 1rem;
      bottom: 1rem;
      left: var(--divider-x);
      width: 1px;
      background: linear-gradient(
        to bottom,
        rgba(138, 121, 87, 0.2),
        rgba(87, 74, 43, 0.55) 46%,
        rgba(138, 121, 87, 0.2)
      );
      box-shadow: 0 0 11px rgba(0, 0, 0, 0.17);
    }

    .page-left,
    .page-right {
      padding-block: clamp(1rem, 2.3vw, 1.85rem);
      position: relative;
    }

    .page-left {
      padding-left: clamp(1rem, 2vw, 1.6rem);
      padding-right: clamp(1.65rem, 3.4vw, 2.45rem);
    }

    .page-right {
      padding-left: clamp(1.65rem, 3.4vw, 2.45rem);
      padding-right: clamp(1rem, 2vw, 1.6rem);
    }

    .page-left::before,
    .page-right::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(0deg, rgba(74, 84, 64, 0.065), rgba(74, 84, 64, 0.065) 1px, transparent 1px, transparent 4px);
      opacity: 0.18;
      pointer-events: none;
    }

    .page-left > *,
    .page-right > * {
      position: relative;
      z-index: 1;
    }

    .recipe-image {
      width: 100%;
      height: clamp(250px, 43vh, 390px);
      object-fit: cover;
      border-radius: 10px;
      border: 1px solid rgba(97, 114, 92, 0.22);
      margin-bottom: 1.05rem;
    }

    .recipe-emoji {
      font-size: 3.2rem;
      line-height: 1;
      margin-bottom: 0.75rem;
      display: block;
    }

    .kicker {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--ink-muted);
      margin-bottom: 0.75rem;
    }

    h1 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4vw, 2.85rem);
      line-height: 1.05;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      text-wrap: balance;
      color: var(--ink);
      text-shadow: 2px 2px 0 rgba(250, 189, 157, 0.6);
    }

    .description {
      color: var(--ink-soft);
      font-size: 1rem;
      line-height: 1.35;
      margin-bottom: 1rem;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-bottom: 0.7rem;
    }

    .tag {
      font-size: 0.62rem;
      font-weight: 700;
      padding: 0.2rem 0.56rem;
      border-radius: 999px;
      border: 1px solid #cbba91;
      background: rgba(253, 239, 215, 0.62);
      color: #315b53;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* Markdown content */
    .content {
      font-size: 1.04rem;
      line-height: 1.45;
      color: #2d4a44;
    }

    .content h2 {
      font-family: var(--font-display);
      font-size: clamp(1.15rem, 3vw, 1.5rem);
      color: #a0461a;
      margin: 0 0 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      text-shadow: 1px 1px 0 rgba(253, 204, 176, 0.6);
      border-bottom: 1px dashed rgba(110, 95, 63, 0.35);
      padding-bottom: 0.3rem;
    }

    .content h2:not(:first-child) {
      margin-top: 1.35rem;
    }

    .content ul, .content ol {
      padding-left: 1.3rem;
      margin-bottom: 0.95rem;
    }

    .content li {
      margin-bottom: 0.42rem;
      font-size: 1rem;
      line-height: 1.5;
    }

    .content p {
      margin-bottom: 0.95rem;
      font-size: 1rem;
      line-height: 1.48;
    }

    .content strong {
      color: var(--ink);
      font-weight: 600;
    }

    .content hr {
      border: none;
      border-top: 1px dashed rgba(105, 90, 58, 0.4);
      margin: 1.3rem 0;
    }

    .content blockquote {
      border-left: 2px solid #c06c3f;
      padding: 0.3rem 0 0.3rem 0.8rem;
      color: #5a726a;
      margin: 0.8rem 0;
    }

    @keyframes enter-spread {
      from {
        transform: translateY(11px) scale(0.985);
        opacity: 0;
      }
      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    @media (max-width: 960px) {
      .spread {
        grid-template-columns: 1fr;
      }

      .spread::after {
        display: none;
      }

      .page-left {
        padding: 1rem;
        border-bottom: 1px dashed rgba(103, 88, 58, 0.45);
      }

      .page-right {
        padding: 1rem;
      }
    }

    @media (max-width: 560px) {
      .content {
        font-size: 0.98rem;
      }
    }

    .recipe-image {
      cursor: pointer;
    }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(0, 0, 0, 0.75);
      align-items: center;
      justify-content: center;
      animation: fade-in 200ms ease-out;
    }

    .lightbox.open {
      display: flex;
    }

    .lightbox-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(0, 0, 0, 0.5);
      border: none;
      color: #fff;
      font-size: 1.5rem;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }

    .lightbox-close:hover {
      background: rgba(0, 0, 0, 0.8);
    }

    .lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
      border-radius: 10px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    @keyframes fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  </style>

  <a class="back" href="/">← All recipes</a>

  <article class="spread">
    <section class="page-left">
      {image
        ? <img class="recipe-image" src={image} alt={title} />
        : <span class="recipe-emoji">{emoji}</span>
      }
      <p class="kicker">Recipe Sheet</p>
      <h1>{title}</h1>
      <p class="description">{description}</p>

      {tags && (
        <div class="tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </section>

    <section class="page-right">
      <div class="content">
        <Content />
      </div>
    </section>
  </article>

  {image && (
    <div class="lightbox" id="lightbox">
      <button class="lightbox-close" id="lightbox-close" aria-label="Close preview">✕</button>
      <img src={image} alt={title} />
    </div>
  )}

  <script>
    const img = document.querySelector('.recipe-image') as HTMLImageElement;
    const lightbox = document.getElementById('lightbox');
    const closeBtn = document.getElementById('lightbox-close');

    if (img && lightbox && closeBtn) {
      img.addEventListener('click', () => lightbox.classList.add('open'));
      closeBtn.addEventListener('click', () => lightbox.classList.remove('open'));
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) lightbox.classList.remove('open');
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') lightbox.classList.remove('open');
      });
    }
  </script>
</Layout>
