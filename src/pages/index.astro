---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const recipes = (await getCollection('recipes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

---

<Layout title="Kitchen">
  <style>
    .hero {
      text-align: center;
      padding: 3rem 1rem 2.5rem;
    }

    .hero h1 {
      font-family: var(--font-serif);
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    .hero h1 em {
      color: var(--accent);
      font-style: italic;
    }

    .hero p {
      color: var(--muted);
      font-size: 1rem;
      max-width: 400px;
      margin: 0 auto;
    }

    /* Recipe grid */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.5rem;
      box-shadow: 0 2px 12px var(--shadow);
      transition: transform 0.2s, box-shadow 0.2s;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      text-decoration: none;
    }

    .card:visited, .card:focus {
      text-decoration: none;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(180, 100, 50, 0.15);
    }

    .card.hidden {
      display: none;
    }

    .card-image {
      width: 100%;
      height: 160px;
      object-fit: cover;
      border-radius: 10px;
      margin-bottom: 0.25rem;
    }

    .card-emoji {
      font-size: 2rem;
      line-height: 1;
    }

    .card-title {
      font-family: var(--font-serif);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.3;
      transition: color 0.2s;
    }

    .card:hover .card-title {
      color: var(--accent);
    }

    .card-meta {
      font-size: 0.78rem;
      color: var(--muted);
      display: flex;
      gap: 0.75rem;
    }

    .card-meta span {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .card-desc {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.5;
      flex: 1;
    }

    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.25rem;
    }

    .tag {
      font-size: 0.7rem;
      font-weight: 500;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      background: var(--green-light);
      color: var(--green);
    }

  </style>

  <div class="hero">
    <h1>Vijaya's <em>Kitchen</em></h1>
    <p>{recipes.length} recipe{recipes.length !== 1 ? 's' : ''} and counting</p>
  </div>

  <div class="grid">
    {recipes.map((recipe) => (
      <a
        class="card"
        href={`/recipes/${recipe.id.replace(/\.md$/, '')}/`}
      >
        {recipe.data.image
          ? <img class="card-image" src={recipe.data.image} alt={recipe.data.title} />
          : <div class="card-emoji">
              {(recipe.data.tags ?? []).includes('salad') ? '🥗' :
               (recipe.data.tags ?? []).includes('soup') ? '🍲' :
               (recipe.data.tags ?? []).includes('indian') ? '🍛' :
               (recipe.data.tags ?? []).includes('chicken') ? '🍗' :
               (recipe.data.tags ?? []).includes('vegan') ? '🌱' : '🍴'}
            </div>
        }
        <div class="card-title">{recipe.data.title}</div>
        {(recipe.data.time || recipe.data.servings) && (
          <div class="card-meta">
            {recipe.data.time && <span>⏱ {recipe.data.time}</span>}
            {recipe.data.servings && <span>👤 serves {recipe.data.servings}</span>}
          </div>
        )}
        <div class="card-desc">{recipe.data.description}</div>
        {recipe.data.tags && (
          <div class="card-tags">
            {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}
      </a>
    ))}
  </div>
</Layout>
