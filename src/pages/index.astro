---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import galleryData from '../content/gallery.json';

const recipes = (await getCollection('recipes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = recipes[0];
const formatDate = (date: Date) => date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const toRecipeUrl = (id: string) => `/recipes/${id.replace(/\.md$/, '')}/`;
const latestNote = latest
  ? `${latest.data.title} was added on ${formatDate(latest.data.date)}.`
  : 'Recipe notes will appear here as you add dishes.';

const heroImages = galleryData.slice(0, 4);
---

<Layout title="Kitchen">
  <style>
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
      gap: 1.1rem;
      margin-bottom: 1.2rem;
    }

    .hero-copy {
      background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0)),
        var(--paper);
      border: 1px solid var(--paper-edge);
      border-radius: var(--radius-md);
      box-shadow: 0 18px 24px rgba(54, 25, 8, 0.25);
      padding: clamp(1.25rem, 3vw, 2.4rem);
      position: relative;
      overflow: hidden;
    }

    .hero-copy::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(0deg, rgba(52, 61, 40, 0.06), rgba(52, 61, 40, 0.06) 1px, transparent 1px, transparent 5px);
      opacity: 0.18;
      pointer-events: none;
    }

    .eyebrow {
      font-family: var(--font-mono);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-size: 0.75rem;
      color: var(--ink-soft);
      margin-bottom: 0.85rem;
      position: relative;
      z-index: 1;
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5.5vw, 3.6rem);
      line-height: 1.03;
      color: var(--ink);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
      position: relative;
      z-index: 1;
      max-width: 11ch;
      text-wrap: balance;
      text-shadow: 3px 3px 0 rgba(247, 171, 136, 0.55);
    }

    .hero h1 em {
      color: var(--accent);
      font-style: normal;
    }

    .hero p {
      color: var(--ink-soft);
      font-size: 1.1rem;
      max-width: 34ch;
      margin-bottom: 1.2rem;
      position: relative;
      z-index: 1;
    }

    .hero-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.6rem 0.75rem;
      position: relative;
      z-index: 1;
    }

    .hero-stamp {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 72px;
      height: 72px;
      border: 2px solid var(--ink);
      border-radius: 999px;
      font-family: var(--font-display);
      font-size: 0.72rem;
      text-transform: uppercase;
      line-height: 1.1;
      color: var(--ink);
      background: rgba(248, 219, 196, 0.62);
      transform: rotate(-11deg);
    }

    .hero-link {
      border: 1px solid var(--ink);
      background: var(--ink);
      color: #fff7e9;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
      transition: transform 0.22s ease, background 0.22s ease;
    }

    .hero-link:hover {
      transform: translateY(-2px);
      background: #123531;
    }

    .cover-panel {
      background: linear-gradient(140deg, #0d5a58, #165955);
      border-radius: var(--radius-md);
      border: 1px solid rgba(225, 243, 231, 0.18);
      padding: 1.05rem;
      box-shadow: 0 18px 24px rgba(42, 18, 6, 0.2);
      display: flex;
      align-items: stretch;
      animation: settle 520ms ease-out;
    }

    .cover-collage {
      width: 100%;
      height: 100%;
      min-height: 280px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .collage-photo {
      position: absolute;
      width: 48%;
      aspect-ratio: 1;
      border-radius: 10px;
      overflow: hidden;
      border: 3px solid rgba(255, 255, 255, 0.25);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .collage-photo:hover {
      z-index: 5;
      transform: scale(1.05) rotate(0deg) !important;
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.4);
    }

    .collage-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .collage-photo-1 { top: 6%; left: 4%; transform: rotate(-5deg); z-index: 2; }
    .collage-photo-2 { top: 4%; right: 4%; transform: rotate(4deg); z-index: 3; }
    .collage-photo-3 { bottom: 10%; left: 8%; transform: rotate(3deg); z-index: 1; }
    .collage-photo-4 { bottom: 8%; right: 6%; transform: rotate(-4deg); z-index: 4; }

    .collage-label {
      position: absolute;
      bottom: 4%;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(246, 219, 200, 0.7);
      z-index: 10;
      white-space: nowrap;
    }

    .notes-strip {
      margin: 0.35rem 0 0.85rem;
      background: rgba(20, 72, 66, 0.86);
      border: 1px solid rgba(214, 230, 215, 0.3);
      border-radius: 10px;
      padding: 0.58rem 0.86rem;
      color: #e7f0dc;
      display: flex;
      align-items: baseline;
      gap: 0.55rem;
    }

    .notes-label {
      font-family: var(--font-display);
      text-transform: uppercase;
      font-size: 0.84rem;
      letter-spacing: 0.06em;
      color: #ffc79f;
      flex-shrink: 0;
    }

    .notes-text {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: #d6e5d2;
      margin: 0;
    }

    .contents-sheet {
      background:
        linear-gradient(150deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0)),
        var(--paper);
      border: 1px solid var(--paper-edge);
      border-radius: 12px;
      box-shadow: 0 10px 22px rgba(72, 32, 11, 0.22);
      padding: clamp(1rem, 2.2vw, 1.7rem);
      position: relative;
      overflow: hidden;
    }

    .contents-sheet::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(0deg, rgba(66, 79, 56, 0.06), rgba(66, 79, 56, 0.06) 1px, transparent 1px, transparent 4px);
      opacity: 0.12;
      pointer-events: none;
    }

    .contents-sheet > * {
      position: relative;
      z-index: 1;
    }

    .contents-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.6rem;
      border-bottom: 1px dashed rgba(92, 79, 53, 0.45);
      padding-bottom: 0.5rem;
    }

    .contents-header h2 {
      font-family: var(--font-display);
      text-transform: uppercase;
      font-size: clamp(1.15rem, 2.2vw, 1.5rem);
      color: var(--ink);
      letter-spacing: 0.05em;
      margin: 0;
    }

    .contents-header span {
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.68rem;
      color: var(--ink-muted);
    }

    .contents-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1.35rem;
      row-gap: 0.25rem;
    }

    .contents-item {
      margin: 0;
    }

    .contents-link {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.34rem 0;
      color: var(--ink);
      transition: color 0.2s ease;
    }

    .contents-title {
      font-family: var(--font-display);
      font-size: clamp(0.9rem, 1.8vw, 1.08rem);
      line-height: 1.1;
      text-transform: uppercase;
    }

    .contents-dots {
      border-bottom: 1px dotted rgba(95, 78, 43, 0.45);
      transform: translateY(-2px);
    }

    .contents-page {
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: var(--ink-muted);
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .contents-link:hover {
      color: #a33d0f;
    }

    /* Gallery section */
    .gallery-sheet {
      margin-top: 1.2rem;
      background:
        linear-gradient(150deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0)),
        var(--paper);
      border: 1px solid var(--paper-edge);
      border-radius: 12px;
      box-shadow: 0 10px 22px rgba(72, 32, 11, 0.22);
      padding: clamp(1rem, 2.2vw, 1.7rem);
      position: relative;
      overflow: hidden;
    }

    .gallery-sheet::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(0deg, rgba(66, 79, 56, 0.06), rgba(66, 79, 56, 0.06) 1px, transparent 1px, transparent 4px);
      opacity: 0.12;
      pointer-events: none;
    }

    .gallery-sheet > * {
      position: relative;
      z-index: 1;
    }

    .gallery-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.8rem;
      border-bottom: 1px dashed rgba(92, 79, 53, 0.45);
      padding-bottom: 0.5rem;
    }

    .gallery-header h2 {
      font-family: var(--font-display);
      text-transform: uppercase;
      font-size: clamp(1.15rem, 2.2vw, 1.5rem);
      color: var(--ink);
      letter-spacing: 0.05em;
      margin: 0;
    }

    .gallery-header span {
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.68rem;
      color: var(--ink-muted);
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }

    .gallery-item {
      position: relative;
      aspect-ratio: 1;
      border-radius: 8px;
      overflow: hidden;
      border: 2px solid rgba(92, 79, 53, 0.2);
      cursor: pointer;
      padding: 0;
      background: none;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .gallery-item:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(72, 32, 11, 0.25);
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }

    .gallery-item:hover img {
      transform: scale(1.05);
    }

    .gallery-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.5rem 0.6rem;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #fff;
      text-align: left;
      opacity: 0;
      transition: opacity 0.25s ease;
    }

    .gallery-item:hover .gallery-caption {
      opacity: 1;
    }

    /* Lightbox */
    .gallery-lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(0, 0, 0, 0.8);
      align-items: center;
      justify-content: center;
      animation: gallery-fade-in 200ms ease-out;
    }

    .gallery-lightbox.open {
      display: flex;
    }

    .gallery-lightbox-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(0, 0, 0, 0.5);
      border: none;
      color: #fff;
      font-size: 1.5rem;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
      z-index: 1001;
    }

    .gallery-lightbox-close:hover {
      background: rgba(0, 0, 0, 0.8);
    }

    .gallery-lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
      border-radius: 10px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    @keyframes gallery-fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes settle {
      from {
        transform: translateY(8px) scale(0.985);
        opacity: 0;
      }
      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    @media (max-width: 930px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .cover-panel {
        max-width: 400px;
        margin: 0 auto;
        min-height: 300px;
      }

      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .hero {
        gap: 0.8rem;
        margin-bottom: 0.8rem;
      }

      .hero-copy {
        padding: 1rem;
      }

      .hero p {
        font-size: 1rem;
      }

      .hero-stamp {
        width: 62px;
        height: 62px;
        font-size: 0.64rem;
      }

      .notes-strip {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.2rem;
      }

      .contents-list {
        grid-template-columns: 1fr;
      }

      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .cover-panel {
        max-width: 100%;
        min-height: 260px;
      }

      .cover-collage {
        min-height: 240px;
      }

      .collage-photo {
        width: 44%;
      }

      .collage-label {
        display: none;
      }

      .gallery-caption {
        opacity: 1;
      }
    }

  </style>

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Issue 01 · Home Edition</p>
      <h1>Vijaya's <em>Kitchen</em></h1>
      <p>A bright little recipe zine with bold flavors, quick weeknight staples, and comfort food from my kitchen notes.</p>
      <div class="hero-footer">
        <span class="hero-stamp">{recipes.length}<br />Recipes</span>
        {latest && <a class="hero-link" href={toRecipeUrl(latest.id)}>Read latest recipe</a>}
      </div>
    </div>
    <div class="cover-panel">
      <div class="cover-collage">
        {heroImages.map((img, i) => (
          <div class={`collage-photo collage-photo-${i + 1}`}>
            <img src={img.src} alt={img.alt} loading="eager" />
          </div>
        ))}
        <span class="collage-label">From the Kitchen</span>
      </div>
    </div>
  </section>

  <div class="notes-strip">
    <span class="notes-label">Kitchen Notes</span>
    <p class="notes-text">{latestNote}</p>
  </div>

  <section class="contents-sheet">
    <div class="contents-header">
      <h2>Recipe Contents</h2>
      <span>Issue 01</span>
    </div>
    <ol class="contents-list">
      {recipes.map((recipe, index) => (
        <li class="contents-item">
          <a class="contents-link" href={`/recipes/${recipe.id.replace(/\.md$/, '')}/`}>
            <span class="contents-title">{recipe.data.title}</span>
            <span class="contents-dots" aria-hidden="true"></span>
            <span class="contents-page">{String(index + 12).padStart(2, '0')}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <section class="gallery-sheet">
    <div class="gallery-header">
      <h2>Photo Gallery</h2>
      <span>{galleryData.length} Photos</span>
    </div>
    <div class="gallery-grid">
      {galleryData.map((img) => (
        <button class="gallery-item" data-src={img.src} data-alt={img.alt} type="button">
          <img src={img.src} alt={img.alt} loading="lazy" />
          <span class="gallery-caption">{img.alt}</span>
        </button>
      ))}
    </div>
  </section>

  <div class="gallery-lightbox" id="gallery-lightbox">
    <button class="gallery-lightbox-close" type="button" aria-label="Close">&times;</button>
    <img src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('gallery-lightbox')!;
    const lightboxImg = lightbox.querySelector('img')!;
    const lightboxClose = lightbox.querySelector('.gallery-lightbox-close')!;

    document.querySelectorAll('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const src = (item as HTMLElement).dataset.src!;
        const alt = (item as HTMLElement).dataset.alt!;
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });

    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }
  </script>
</Layout>
